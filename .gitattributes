# This repo is deployed to Linux. Force LF on everything executed or sourced
# there so a Windows checkout never ships CRLF that breaks shebangs/heredocs.
*.sh        text eol=lf
*.py        text eol=lf
*.conf      text eol=lf
*.iql       text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.service   text eol=lf
*.db        text eol=lf
default     text eol=lf
adjust-scripts-s6-sh text eol=lf

# Binary-ish assets: leave untouched.
*.png       binary
